rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Service requests collection
    match /service_requests/{document} {
      allow read: if true;  // Allow public read for admin panel
      allow create: if true;  // Allow public creation
      allow update, delete: if true;  // Allow updates and deletes
    }
    
    // Contact messages collection
    match /contact_messages/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;  // Prevent modification
    }
  }
}